<Window x:Class="AnimeTagsEditor.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PG-ContentManager — P/G Studio" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f0f" 
        Foreground="#E0E0E0"
        ResizeMode="CanResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 🔝 Шапка с логотипом (перетаскиваемая) -->
        <Border Grid.Row="0" 
                Background="#1E1E1E" 
                CornerRadius="10" 
                Padding="20" 
                Margin="0,0,0,20"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип -->
                <Border Grid.Column="0" Width="80" Height="80" CornerRadius="40" Background="#F1C40F" Margin="0,0,20,0">
                    <TextBlock Text="🎌" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Информация -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="PG-ContentManager" FontSize="32" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Приложение для работы с сайтом playgame-studio.ru" FontSize="14" Foreground="#888888" Margin="0,5,0,0"/>
                    <TextBlock Text="P/G Studio • v0.1.0" FontSize="12" Foreground="#666666" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 📰 Основная часть -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Новости -->
            <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="10" Padding="20" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="📰 Что нового" FontSize="24" FontWeight="Bold" Foreground="#F1C40F" Margin="0,0,0,15"/>

                    <Border Background="#252525" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="🎉 Первый релиз v0.1.0" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="• Создан редактор JSON файлов с тегами аниме" FontSize="13" Foreground="#AAA" Margin="0,5,0,0"/>
                            <TextBlock Text="• Поддержка категорий и пользовательских тегов" FontSize="13" Foreground="#AAA" Margin="0,3,0,0"/>
                            <TextBlock Text="• Предварительный просмотр как на сайте" FontSize="13" Foreground="#AAA" Margin="0,3,0,0"/>
                            <TextBlock Text="• Self-contained сборка (один .exe файл)" FontSize="13" Foreground="#AAA" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#252525" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="🚀 Возможности" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="• Создание и редактирование тегов" FontSize="13" Foreground="#AAA" Margin="0,5,0,0"/>
                            <TextBlock Text="• Удаление категорий и тегов" FontSize="13" Foreground="#AAA" Margin="0,3,0,0"/>
                            <TextBlock Text="• Экспорт в JSON" FontSize="13" Foreground="#AAA" Margin="0,3,0,0"/>
                            <TextBlock Text="• Интеграция с playgame-studio.ru" FontSize="13" Foreground="#AAA" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Быстрые действия -->
            <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text=" Быстрый старт" FontSize="20" FontWeight="Bold" Foreground="#F1C40F" Margin="0,0,0,15"/>

                    <Button Content="📄 Создать новый проект" 
                            Background="#9C27B0" 
                            Foreground="White" 
                            Height="50" 
                            FontSize="14"
                            FontWeight="SemiBold"
                            Margin="0,0,0,10"
                            Click="CreateNew_Click"
                            Cursor="Hand"/>

                    <Button Content="📂 Открыть существующий" 
                            Background="#2196F3" 
                            Foreground="White" 
                            Height="50" 
                            FontSize="14"
                            FontWeight="SemiBold"
                            Margin="0,0,0,10"
                            Click="OpenExisting_Click"
                            Cursor="Hand"/>

                    <Button Content="🎬 Перейти к редактору" 
                            Background="#4CAF50" 
                            Foreground="White" 
                            Height="50" 
                            FontSize="14"
                            FontWeight="Bold"
                            Margin="0,0,0,20"
                            Click="OpenEditor_Click"
                            Cursor="Hand"/>

                    <TextBlock Text="📁 Недавние файлы" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>

                    <StackPanel x:Name="RecentFilesPanel">
                        <TextBlock Text="Нет недавних файлов" Foreground="#666" FontSize="12" FontStyle="Italic"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 🔽 Подвал -->
        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="10" Padding="15" Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="© 2026 P/G Studio • Все права защищены" FontSize="12" Foreground="#666"/>
                    <TextBlock FontSize="11" Foreground="#555"><Run Text="Разработано для playgame-studio.ru"/><Run Text=" от GREYCATNERO (GCN)"/></TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="💬 Discord" Background="Transparent" BorderBrush="#5865F2" Foreground="#5865F2" Padding="10,5" Margin="5,0,0,0"/>
                    <Button Content="✈️ Telegram" Background="Transparent" BorderBrush="#0088CC" Foreground="#0088CC" Padding="10,5" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>